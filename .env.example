# Server
PORT=3000
LOG_LEVEL=info

# Static asset root (absolute or relative to server cwd)
STATIC_ROOT=./public

# JWT
JWT_SECRET=please-change-me-to-a-long-random-string-32chars+
JWT_EXPIRES_IN=2h

# Admin credentials (run `pnpm gen:hash <password>` to produce the hash)
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=

# Upload
MAX_UPLOAD_SIZE_MB=50

# Reserved URL prefixes (comma-separated). Files under STATIC_ROOT with these
# top-level names will be shadowed by application routes and unreachable via URL.
RESERVED_PREFIXES=/api,/admin
